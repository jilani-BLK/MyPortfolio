---
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import Comments from "@components/Comments"
---

<PageLayout title="Laisser un avis" description="Laissez un mot, un retour ou un simple bonjour.">
  <TopLayout>
    <div class="animate page-heading">
      Laisser un avis
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <p class="opacity-75">
        Un mot, un retour, une remarque ou un simple bonjour — laissez une trace ici. Je lis tout, et je réponds. 🙂
      </p>
      <Comments client:load pageKey="global" />
    </div>
  </BottomLayout>
</PageLayout>
